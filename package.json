{
  "name": "pr-replies",
  "version": "2.6.0",
  "private": true,
  "description": "Triage, fix, and reply to GitHub PR / GitLab MR comments in a live browser session — with dual reply drafts (direct + humanized), history, and reply templates. Works with Claude Code and OpenAI Codex.",
  "license": "MIT",
  "scripts": {
    "test": "node --test test/*.test.js",
    "ui:preview": "node scripts/ui-preview.js",
    "ui:preview:headed": "node scripts/ui-preview.js --headed",
    "home": "node server/server.js serve --home",
    "build:agents": "node scripts/build-agents.js",
    "check:agents": "node scripts/check-agents.js",
    "install:codex": "node scripts/install-codex.js",
    "sync:version": "node scripts/sync-version.js",
    "check:version": "node scripts/check-version.js",
    "preversion": "npm test",
    "version": "npm run sync:version && git add .claude-plugin/plugin.json",
    "postversion": "git push --follow-tags"
  },
  "devDependencies": {
    "playwright": "^1.48.0"
  }
}
